{
  "manifest_version": 3,
  "name": "在线课程助手 (自动翻页版) - 乱选速刷",
  "version": "5.2.2",
  "description": "智能排队刷课、自动翻页、无脑乱选速刷（仅供技术交流）。",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.chaoxing.com/*",
        "*://*.erya100.com/*",
        "*://*.xuexitong.com/*"
      ],
      "js": [
        "utils.js",
        "pagination.js",
        "ui.js",
        "video.js",
        "doc.js",
        "solver.js",
        "main.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "online-course-assistant@tomgranger.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}